{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/edit-guard.sh\"'",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/bash-failure-guard.sh\"'",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/bash-guard.sh\"'",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/inject-iron-laws.sh\"'",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/setup-dirs.sh\"'",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/detect-tidewave.sh\"'",
            "timeout": 30,
            "statusMessage": "Detecting Tidewave..."
          },
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/check-scratchpad.sh\"'",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/check-resume.sh\"'",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/check-branch-freshness.sh\"'",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/precompact-rules.sh\"'",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/postcompact-verify.sh\"'",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec /bin/bash \"$PLUGIN_ROOT/hooks/scripts/check-pending-plans.sh\"'",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
